{
    "manifest_version" : 3,
    "name" : "Question lable remover",
    "version" : "1.0",

    "permissions" : ["activeTab", "scripting", "storage"],

    "action":{
        "default_popup" : "popup.html",
        "default_icon" : "icon16.png"
    },

    "icons":{
        "128": "icon128.png",
        "48" : "icon48.png",
        "16" : "icon16.png"
    },

    "content_scripts" :[
        {
            "matches" : ["https://leetcode.com/problems/*", "https://leetcode.com/problemset/*"],
            "js" : ["content.js"]
        }
    ]
}