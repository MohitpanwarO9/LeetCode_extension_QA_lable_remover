{
    "manifest_version" : 3,
    "name" : "Question lable remover",
    "version" : "1.0",

    "permissions" : ["activeTab", "scripting", "storage"],

    "action":{
        "default_popup" : "popup.html"
    },

    "content_scripts" :[
        {
            "matches" : ["https://leetcode.com/problems/*", "https://leetcode.com/problemset/*"],
            "js" : ["content.js"]
        }
    ]
}